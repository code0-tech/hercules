{
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "commonjs",
    "target": "es2020",
    "lib": ["ESNext", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "baseUrl": "src/"
  },
  "exclude": [
    "node_modules",
    "dist",
    "examples"
  ],
  "types": [
    "typePatches"
  ]
}