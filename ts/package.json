{
  "name": "@code0-tech/hercules",
  "version": "0.0.0",
  "description": "TypeScript SDK for the hercules action runner",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code0-tech/hercules.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:definitions && vite build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:definitions": "npx tsx scripts/build-definitions.ts -- --version def-0.0.28"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
  },
  "devDependencies": {
    "@code0-tech/tucana": "0.0.74",
    "@grpc/grpc-js": "^1.14.3",
    "@protobuf-ts/grpc-backend": "^2.11.1",
    "@protobuf-ts/grpc-transport": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^28.0.0",
    "ts-to-zod": "^5.1.0",
    "zod": "^4.4.3",
    "zod-to-ts": "^2.1.0",
    "@types/node": "^25.0.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@code0-tech/tucana": "0.0.74",
    "@grpc/grpc-js": "^1.14.3",
    "@protobuf-ts/grpc-backend": "^2.11.1",
    "@protobuf-ts/grpc-transport": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^28.0.0",
    "ts-to-zod": "^5.1.0",
    "zod": "^4.4.3",
    "zod-to-ts": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
